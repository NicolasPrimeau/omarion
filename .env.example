# Copy to .env — run `python scripts/seed_keys.py` to auto-generate AGENT_KEYS

# Server
AGENT_KEYS=nimbus:changeme,archivist:changeme,steward:changeme

# Archivist (must match the archivist key in AGENT_KEYS)
ANTHROPIC_API_KEY=sk-ant-...
ARCHIVIST_KEY=changeme

# MCP server — identity used when Claude Code connects via SSE
# Override per-client when using stdio transport (set in Claude Code MCP env config)
MCP_AGENT_ID=nimbus
MCP_AGENT_KEY=changeme
