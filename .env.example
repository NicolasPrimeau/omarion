# Copy to .env — run `python scripts/seed_keys.py` to auto-generate AGENT_KEYS
# UI
UI_PASSWORD=changeme

# Server — format: agent-id:api-key, comma-separated. Optional third segment scopes to projects.
# The archivist and MCP containers derive their keys from this list automatically.
AGENT_KEYS=archivist:changeme,mcp:changeme

# Registration key — required to register new agents (leave blank to disable)
REGISTRATION_KEY=

# LLM for the archivist — optional. Without this, decay and promotion still run.
# Provider: anthropic (default) | openai
ARCHIVIST_PROVIDER=anthropic
ARCHIVIST_MODEL=                   # leave blank for provider default (claude-sonnet-4-6 / gpt-4o)
ARCHIVIST_API_KEY=                 # falls back to ANTHROPIC_API_KEY when provider=anthropic
ARCHIVIST_BASE_URL=                # OpenAI-compatible base URL (Ollama, Mistral, etc.)
ANTHROPIC_API_KEY=sk-ant-...
